# ===== Unity 자동 생성 폴더 =====
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# ===== 에셋 meta 파일은 유지 (언어 서버/협업에 필수) =====
!/[Aa]ssets/**/*.meta

# ===== IDE / 솔루션 파일 (Unity가 재생성) =====
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ===== JetBrains Rider 자동 생성 플러그인 =====
/[Aa]ssets/Plugins/Editor/JetBrains*

# ===== Addressables / StreamingAssets 임시 산출물 =====
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ===== Unity 크래시 리포트 =====
sysinfo.txt
crashlytics-build.properties

# ===== OS 파일 =====
.DS_Store
Thumbs.db
desktop.ini
